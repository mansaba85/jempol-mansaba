generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model attendance {
  id         Int      @id @default(autoincrement())
  employeeId Int
  timestamp  DateTime
  type       String
  deviceId   Int?
  isManual   Boolean  @default(false)
  note       String?
  employee   employee @relation(fields: [employeeId], references: [id], map: "Attendance_employeeId_fkey")

  @@unique([employeeId, timestamp], map: "Attendance_employeeId_timestamp_key")
  @@index([employeeId], map: "Attendance_employeeId_idx")
  @@index([timestamp], map: "Attendance_timestamp_idx")
}

model category {
  id        Int         @id @default(autoincrement())
  name      String      @unique(map: "Category_name_key")
  createdAt DateTime    @default(now())
  timetable timetable[]
}

model device {
  id        Int       @id @default(autoincrement())
  name      String
  ipAddress String    @unique(map: "Device_ipAddress_key")
  port      Int       @default(4370)
  password  String?
  lastSync  DateTime?
  isActive  Boolean   @default(true)
}

model employee {
  id              Int               @id
  nip             String?
  name            String
  role            String?           @default("GURU")
  transportRate   Float             @default(0)
  fingerId        String?
  cardNo          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  isSertifikasi   Boolean           @default(false)
  pin             String?           @unique(map: "Employee_pin_key")
  attendance      attendance[]
  employeepattern employeepattern[]
  employeeshift   employeeshift[]
  honor           honor[]
}

model employeepattern {
  id           Int          @id @default(autoincrement())
  employeeId   Int
  patternId    Int
  startDate    DateTime
  employee     employee     @relation(fields: [employeeId], references: [id], map: "EmployeePattern_employeeId_fkey")
  shiftpattern shiftpattern @relation(fields: [patternId], references: [id], map: "EmployeePattern_patternId_fkey")

  @@index([employeeId], map: "EmployeePattern_employeeId_idx")
  @@index([patternId], map: "EmployeePattern_patternId_fkey")
}

model employeeshift {
  id         Int      @id @default(autoincrement())
  employeeId Int
  shiftId    Int
  employee   employee @relation(fields: [employeeId], references: [id], map: "EmployeeShift_employeeId_fkey")
  shift      shift    @relation(fields: [shiftId], references: [id], map: "EmployeeShift_shiftId_fkey")

  @@unique([employeeId, shiftId], map: "EmployeeShift_employeeId_shiftId_key")
  @@index([shiftId], map: "EmployeeShift_shiftId_fkey")
}

model honor {
  id          Int      @id @default(autoincrement())
  month       Int
  year        Int
  employeeId  Int
  totalDays   Int
  totalAmount Float
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  employee    employee @relation(fields: [employeeId], references: [id], map: "Honor_employeeId_fkey")

  @@index([employeeId], map: "Honor_employeeId_idx")
  @@index([month, year], map: "Honor_month_year_idx")
}

model masterschedule {
  id         Int          @id @default(autoincrement())
  name       String
  isActive   Boolean      @default(false)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime     @default(now())
  shiftgroup shiftgroup[]
}

model shift {
  id              Int             @id @default(autoincrement())
  groupId         Int?
  name            String
  startTime       String
  endTime         String
  lateTolerance   Int             @default(0)
  earlyTolerance  Int             @default(0)
  startScanIn     String
  endScanIn       String
  startScanOut    String
  endScanOut      String
  workDayValue    Float           @default(1)
  workMinuteValue Int             @default(0)
  days            String          @default("1,2,3,4,5,6")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  employeeshift   employeeshift[]
  shiftgroup      shiftgroup?     @relation(fields: [groupId], references: [id], map: "Shift_groupId_fkey")

  @@index([groupId], map: "Shift_groupId_fkey")
}

model shiftgroup {
  id               Int             @id @default(autoincrement())
  masterScheduleId Int?
  name             String
  createdAt        DateTime        @default(now())
  shift            shift[]
  masterschedule   masterschedule? @relation(fields: [masterScheduleId], references: [id], map: "ShiftGroup_masterScheduleId_fkey")

  @@index([masterScheduleId], map: "ShiftGroup_masterScheduleId_fkey")
}

model shiftpattern {
  id               Int                @id @default(autoincrement())
  category         String             @default("Umum")
  name             String
  cycleDays        Int                @default(7)
  createdAt        DateTime           @default(now())
  startDate        DateTime?
  employeepattern  employeepattern[]
  shiftpatternitem shiftpatternitem[]
}

model shiftpatternitem {
  id           Int          @id @default(autoincrement())
  patternId    Int
  timetableId  Int
  dayNumber    Int
  shiftpattern shiftpattern @relation(fields: [patternId], references: [id], map: "ShiftPatternItem_patternId_fkey")
  timetable    timetable    @relation(fields: [timetableId], references: [id], map: "ShiftPatternItem_timetableId_fkey")

  @@index([patternId], map: "ShiftPatternItem_patternId_fkey")
  @@index([timetableId], map: "ShiftPatternItem_timetableId_fkey")
}

model systemsetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique(map: "SystemSetting_key_key")
  value     String   @db.LongText
  updatedAt DateTime
}

model timetable {
  id               Int                @id @default(autoincrement())
  name             String
  jamMasuk         String
  jamPulang        String
  mulaiScanIn      String?
  akhirScanIn      String?
  mulaiScanOut     String?
  akhirScanOut     String?
  color            String?            @default("#086862")
  createdAt        DateTime           @default(now())
  days             String?            @default("1,2,3,4,5,6")
  categoryId       Int?
  categoryName     String?
  shiftpatternitem shiftpatternitem[]
  category         category?          @relation(fields: [categoryId], references: [id], map: "Timetable_categoryId_fkey")

  @@index([categoryId], map: "Timetable_categoryId_fkey")
}

model user {
  id        Int      @id @default(autoincrement())
  username  String   @unique(map: "User_username_key")
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}
